{
  "name": "hq",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,green \"PORT=8787 node --experimental-strip-types --experimental-specifier-resolution=node ./server/index.ts\" \"vite\"",
    "dev:server": "node --experimental-strip-types --experimental-specifier-resolution=node ./server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build && esbuild ./server/index.ts --bundle --platform=node --format=esm --outfile=dist-server/server/index.js --packages=external",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "PORT=4173 node ./dist-server/server/index.js",
    "start": "node ./dist-server/server/index.js",
    "hq": "./cli/hq/bin/hq",
    "aweber": "./cli/aweber/bin/aweber",
    "ebook": "./cli/ebook/bin/ebook",
    "framer": "./cli/framer/bin/framer",
    "bootstrap:hq": "node --experimental-strip-types --experimental-specifier-resolution=node ./scripts/bootstrap-hq.ts",
    "grant:super-admin": "node --experimental-strip-types --experimental-specifier-resolution=node ./scripts/grant-super-admin.ts",
    "db:migrate:uuid-ids": "node --experimental-strip-types --experimental-specifier-resolution=node ./scripts/migrate-uuid-ids-to-integers.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types --experimental-specifier-resolution=node ./scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@better-auth/drizzle-adapter": "^1.4.18",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hono/node-server": "^1.19.9",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.27.5",
    "@neondatabase/serverless": "^1.0.2",
    "framer-api": "^0.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "@types/pg": "^8.16.0",
    "@uidotdev/usehooks": "^2.4.1",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "geist": "^1.7.0",
    "hono": "^4.11.9",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.2",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "playwright": "^1.58.2",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "7",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.4.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
